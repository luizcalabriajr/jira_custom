<odoo>
    <record id="view_helpdesk_ticket_form_jira" model="ir.ui.view">
        <field name="name">helpdesk.ticket.jira</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Jira">
                    <group>
                        <field name="jira_issue_id"/>
                        <field name="jira_key"/>
                        <field name="jira_url"/>
                        <field name="jira_sync_status"/>
                        <button name="action_create_jira_from_ticket"
                                type="object"
                                string="Criar Issue no Jira"
                                class="btn-primary"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
